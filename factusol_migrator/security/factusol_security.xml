<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_factusol" model="ir.module.category">
        <field name="name">FactuSol</field>
        <field name="description">Migrador FactuSol → Odoo by GoxTech</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_factusol_user" model="res.groups">
        <field name="name">Migrador FactuSol / Usuario</field>
        <field name="category_id" ref="module_category_factusol"/>
        <field name="comment">Puede consultar bases, ejecuciones e incidencias.</field>
    </record>

    <record id="group_factusol_manager" model="res.groups">
        <field name="name">Migrador FactuSol / Manager</field>
        <field name="category_id" ref="module_category_factusol"/>
        <field name="comment">Ejecuta migraciones; gestiona perfiles, bases y catálogo.</field>
        <field name="implied_ids" eval="[(4, ref('group_factusol_user')),
            (4, ref('account.group_account_manager')),
            (4, ref('sales_team.group_sale_salesman')),
            (4, ref('purchase.group_purchase_user')),
            (4, ref('stock.group_stock_user'))]"/>
    </record>

</odoo>
