<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_factusol_import_profile_list" model="ir.ui.view">
        <field name="name">factusol.import.profile.list</field>
        <field name="model">factusol.import.profile</field>
        <field name="arch" type="xml">
            <list string="Perfiles de importación">
                <field name="name"/>
                <field name="is_preset"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_factusol_import_profile_form" model="ir.ui.view">
        <field name="name">factusol.import.profile.form</field>
        <field name="model">factusol.import.profile</field>
        <field name="arch" type="xml">
            <form string="Perfil de importación">
                <header>
                    <button name="action_clone" type="object" string="Clonar"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Preset" invisible="not is_preset"/>
                    <group>
                        <field name="name" readonly="is_preset"/>
                        <field name="is_preset" invisible="1"/>
                        <field name="description" readonly="is_preset"/>
                    </group>
                    <field name="line_ids" readonly="is_preset">
                        <list editable="bottom">
                            <field name="plane"/>
                            <field name="entity_label"/>
                            <field name="entity" column_invisible="1"/>
                            <field name="enabled" widget="boolean_toggle"/>
                            <field name="field_whitelist"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_factusol_import_profile" model="ir.actions.act_window">
        <field name="name">Perfiles</field>
        <field name="res_model">factusol.import.profile</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
