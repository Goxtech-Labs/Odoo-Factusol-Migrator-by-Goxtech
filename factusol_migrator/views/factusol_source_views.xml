<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_factusol_source_list" model="ir.ui.view">
        <field name="name">factusol.source.list</field>
        <field name="model">factusol.source</field>
        <field name="arch" type="xml">
            <list string="Bases FactuSol">
                <field name="name"/>
                <field name="company_code"/>
                <field name="fiscal_year"/>
                <field name="backend"/>
                <field name="table_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'ready'"
                       decoration-danger="state == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_factusol_source_form" model="ir.ui.view">
        <field name="name">factusol.source.form</field>
        <field name="model">factusol.source</field>
        <field name="arch" type="xml">
            <form string="Base FactuSol">
                <header>
                    <button name="action_scan" type="object" string="Analizar"
                            class="btn-primary"/>
                    <button name="action_purge_file" type="object" string="Borrar fichero"
                            confirm="¿Borrar el .accdb? Se conservan los metadatos."/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="accdb_file" filename="file_name"/>
                            <field name="file_name"/>
                            <field name="password" password="True"/>
                        </group>
                        <group>
                            <field name="company_code"/>
                            <field name="fiscal_year"/>
                            <field name="backend"/>
                            <field name="table_count"/>
                        </group>
                    </group>
                    <field name="note" readonly="1" invisible="not note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_factusol_source" model="ir.actions.act_window">
        <field name="name">Bases (.accdb)</field>
        <field name="res_model">factusol.source</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
